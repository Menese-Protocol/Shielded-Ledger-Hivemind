{
  "version": 1,
  "defaults": {
    "build": {
      "packtool": "mops sources"
    }
  },
  "canisters": {
    "tree_oracle": {
      "type": "custom",
      "candid": "../vendor/tree_oracle_bls/tree_oracle_bls.did",
      "wasm": "../vendor/tree_oracle_bls/tree_oracle_bls.wasm"
    },
    "zk_ledger": {
      "type": "motoko",
      "main": "../src/Main.mo"
    },
    "demo_token": {
      "type": "motoko",
      "main": "DemoTokenLedger.mo"
    },
    "demo_directory": {
      "type": "motoko",
      "main": "../tests/DemoDirectory.mo"
    },
    "demo_frontend": {
      "type": "assets",
      "source": ["dist"]
    }
  },
  "networks": {
    "local": {
      "bind": "127.0.0.1:4955",
      "type": "ephemeral"
    }
  }
}
